{
  "env": {
    "ECC_OBSERVER_TIMEOUT_SECONDS": "300",
    "ECC_OBSERVER_MAX_TURNS": "50"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/sandbox-safe-shell.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      },
      {
        "matcher": "mcp__claude-in-chrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/cic-preflight-reminder.sh"
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Supabase__apply_migration|mcp__claude_ai_Supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/supabase-write-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/git-push-review-reminder.sh",
            "if": "Bash(git push*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/.claude/feedback_operating_manual.md"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/.claude/feedback_operating_manual.md"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "glass@claude-code-notify": false,
    "cartographer@cartographer-marketplace": true,
    "ralph-loop@claude-plugins-official": false,
    "claude-supermemory@supermemory-plugins": false,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "video-maker@renoise-plugins-official": false,
    "warp@claude-code-warp": true,
    "obsidian@obsidian-skills": true,
    "linkedin-skills@linkedin-skills": true,
    "skill-creator@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "linkedin-skills": {
      "source": {
        "source": "github",
        "repo": "sergebulaev/linkedin-skills"
      }
    }
  },
  "effortLevel": "high",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
