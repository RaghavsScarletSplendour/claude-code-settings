{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/sandbox-safe-shell.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "glass@claude-code-notify": true,
    "cartographer@cartographer-marketplace": true,
    "ralph-loop@claude-plugins-official": false,
    "claude-supermemory@supermemory-plugins": false,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "video-maker@renoise-plugins-official": false,
    "warp@claude-code-warp": true,
    "obsidian@obsidian-skills": true,
    "linkedin-skills@linkedin-skills": true,
    "skill-creator@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "ponytail@ponytail": false
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "linkedin-skills": {
      "source": {
        "source": "github",
        "repo": "sergebulaev/linkedin-skills"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "medium",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
